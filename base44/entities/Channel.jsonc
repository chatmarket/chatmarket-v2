      "type": "string",
      "enum": [
        "fortune_telling",
        "idol",
        "business",
        "language",
        "fitness",
        "education",
        "other"
      ],
      "default": "other",
      "description": "\u30b5\u30fc\u30d3\u30b9\u30ab\u30c6\u30b4\u30ea\uff08\u6a5f\u80fd\u5236\u5fa1\u306b\u4f7f\u7528\uff09\u3002fortune_telling=\u5360\u3044\u5e2b\u5c02\u7528\u6a5f\u80fd\u6709\u52b9, idol=\u30c7\u30b8\u30bf\u30eb\u30c1\u30a7\u30ad\u6a5f\u80fd\u6709\u52b9"
    },
