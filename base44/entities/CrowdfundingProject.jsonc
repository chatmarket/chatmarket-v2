      "type": "string",
      "description": "\u753b\u50cf1URL"
    },
    "image_url_2": {
      "type": "string",
      "description": "\u753b\u50cf2URL"
    },
    "image_url_3": {
      "type": "string",
      "description": "\u753b\u50cf3URL"
    },
