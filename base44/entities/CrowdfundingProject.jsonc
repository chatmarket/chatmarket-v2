    "admin_note": {
      "type": "string",
      "description": "\u5be9\u67fb\u62c5\u5f53\u8005\u30e1\u30e2"
    },
    "goal_amount": {
      "type": "number",
      "default": 0,
      "description": "\u76ee\u6a19\u91d1\u984d\uff080\u306e\u5834\u5408\u306f\u76ee\u6a19\u306a\u3057\uff09"
    },
    "total_raised": {
      "type": "number",
      "default": 0,
      "description": "\u7d2f\u8a08\u652f\u63f4\u91d1\u984d"
    },
    "supporter_count": {
      "type": "number",
      "default": 0,
      "description": "\u652f\u63f4\u8005\u6570"
    }
  },
  "required": [
    "title",
    "organization_name",
    "organization_type",
    "representative_name",
    "contact_name",
    "contact_phone",
    "address"
  ]
}