import { useEffect, useRef, useState } from "react";

/**
 * useStreamSpeech
 * チャットやエールを音声で読み上げるカスタムフック
 * Web Speech API の複数音声対応
 * 
 * 使用例:
 * const { isSpeaking, speak, voices, selectedVoice, setSelectedVoice } = useStreamSpeech();
 */
export default function useStreamSpeech() {
  const [isSpeaking, setIsSpeaking] = useState(false);
  const [voices, setVoices] = useState([]);
  const [selectedVoice, setSelectedVoice] = useState(null);
  const synth = useRef(null);

  useEffect(() => {
    // ブラウザの音声合成APIを初期化
    if (typeof window !== "undefined") {
      synth.current = window.speechSynthesis;

      // 利用可能な音声を取得
      const updateVoices = () => {
        const availableVoices = synth.current.getVoices();
        // 日本語の音声をフィルタ
        const japaneseVoices = availableVoices.filter((v) => v.lang.startsWith("ja"));
        setVoices(japaneseVoices.length > 0 ? japaneseVoices : availableVoices);
        
        // デフォルト音声を選択
        if (japaneseVoices.length > 0 && !selectedVoice) {
          setSelectedVoice(japaneseVoices[0]);
        }
      };

      // 音声リストの読み込み完了時
      synth.current.onvoiceschanged = updateVoices;
      updateVoices();
    }
  }, [selectedVoice]);

  const speak = (text, voiceOverride = null) => {
    if (!synth.current) return;

    synth.current.cancel();

    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = "ja-JP";
    utterance.rate = 1.2;
    utterance.pitch = 1;
    utterance.voice = voiceOverride || selectedVoice;

    utterance.onstart = () => setIsSpeaking(true);
    utterance.onend = () => setIsSpeaking(false);
    utterance.onerror = () => setIsSpeaking(false);

    synth.current.speak(utterance);
  };

  const cancel = () => {
    if (synth.current) {
      synth.current.cancel();
      setIsSpeaking(false);
    }
  };

  const toggleSpeech = () => {
    if (isSpeaking) {
      cancel();
    }
  };

  return { isSpeaking, speak, cancel, toggleSpeech, voices, selectedVoice, setSelectedVoice };
}